<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hotel_room_tree" model="ir.ui.view">
        <field name="name">hotel.room.tree</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <tree string="Rooms">
                <field name="currency_id" invisible="1"/>
                <field name="name"/>
                <field name="room_type"/>
                <field name="price_per_night"/>
                <field name="is_available"/>
            </tree>
        </field>
    </record>

    <record id="view_hotel_room_form" model="ir.ui.view">
        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form string="Room Form">
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="room_type"/>
                        </group>
                        <group>
                            <field name="price_per_night"/>
                            <field name="is_available"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hotel_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hotel_room" name="Rooms" parent="menu_hotel_mgmt_root" action="action_hotel_room" sequence="20"/>

</odoo>
